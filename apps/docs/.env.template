# LLM backend (LiteLLM proxy — used by the app and persona simulation)
LLM_HOST=http://localhost:4000/v1
LLM_API_KEY=xxxxxxxxx
LLM_MODEL_NAME=your-model-name

# Supabase
NEXT_PUBLIC_SUPABASE_URL=xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Langfuse (optional, for LLM tracing)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASEURL="https://cloud.langfuse.com"

# CDN Evaluation (optional — only needed for `pnpm eval`)
# EVAL_BASE_URL=https://interact-molt.vercel.app  # App URL (default: deployed)
# EVAL_SIM_MODEL=                                  # Override LLM_MODEL_NAME for persona simulation (cheap/fast model)
# EVAL_JUDGE_HOST=                                 # LLM host for judging (defaults to LLM_HOST)
# EVAL_JUDGE_KEY=                                  # API key for judge (defaults to LLM_API_KEY)
# EVAL_JUDGE_MODEL=                                # Model for CDN judging (capable model, e.g. claude-sonnet-4-5-20250514)
# EVAL_JUDGE_RUNS=1                                # Number of judge runs per session
